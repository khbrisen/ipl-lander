---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABox from '../components/CTABox.astro';

const title = 'Bet on IPL 2025 with Babu88 — Claim Your Cricket Bonus';
const description = 'Join Babu88 for the best IPL 2025 betting odds, live cricket markets, and exclusive welcome bonus. Fast deposits, instant withdrawals, and 24/7 support for Indian players.';

const schemaOrg = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Babu88',
      url: 'https://ipl-cricket-in.netlify.app',
      description: 'Babu88 — Trusted IPL cricket betting platform for Indian players.',
    },
    {
      '@type': 'WebSite',
      name: 'Babu88 IPL Cricket',
      url: 'https://ipl-cricket-in.netlify.app',
    },
    {
      '@type': 'SportsEvent',
      name: 'Indian Premier League 2025',
      sport: 'Cricket',
      location: {
        '@type': 'Country',
        name: 'India',
      },
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </Fragment>

  <!-- Age Gate -->
  <div class="age-gate">18+ | Play Responsibly | Gambling involves risk</div>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>IPL 2025 Betting <span>on Babu88</span></h1>
      <p class="subtitle">Best odds on every IPL match. Live markets, fast payouts, exclusive bonuses.</p>
      <CTABox text="Claim Your IPL Bonus" href="#signup" />
    </div>
  </section>

  <!-- Video Section -->
  <section>
    <div class="container">
      <h2>Watch. Bet. Win.</h2>
      <div class="video-wrapper">
        <!-- Replace with your embed: <iframe src="..." ...></iframe> -->
        Video embed placeholder — replace with IPL promo video
      </div>
      <div style="text-align:center;">
        <CTABox text="Start Betting Now" href="#signup" />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section>
    <div class="container">
      <h2>Why Bet IPL on Babu88?</h2>
      <div class="features">
        <div class="feature-card">
          <div class="icon">&#127951;</div>
          <h3>Live IPL Markets</h3>
          <p>Ball-by-ball odds on every match. Bet on top batsman, total runs, match winner, and 50+ markets per game.</p>
        </div>
        <div class="feature-card">
          <div class="icon">&#128176;</div>
          <h3>Instant Deposits</h3>
          <p>UPI, Paytm, PhonePe, and bank transfer. Funds hit your account in seconds so you never miss a bet.</p>
        </div>
        <div class="feature-card">
          <div class="icon">&#9889;</div>
          <h3>Fast Withdrawals</h3>
          <p>Cash out your winnings quickly. Most withdrawals processed within hours, not days.</p>
        </div>
        <div class="feature-card">
          <div class="icon">&#127873;</div>
          <h3>IPL Welcome Bonus</h3>
          <p>New to Babu88? Get an exclusive cricket bonus on your first deposit. More runs, more rewards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-strip">
    <p>The IPL season is live — don't miss your chance to win big.</p>
    <CTABox text="Join Babu88 Now" href="#signup" />
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <p>Gambling can be addictive. Play responsibly. 18+ only.</p>
      <p style="margin-top:8px;">
        &copy; 2025 Babu88. All rights reserved. |
        <a href="#signup">Affiliate Disclosure</a>
      </p>
    </div>
  </footer>
</BaseLayout>
