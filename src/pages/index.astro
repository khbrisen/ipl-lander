---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Babu88 — Bet on IPL 2025';
const description = 'Join Babu88 for the best IPL 2025 betting odds and exclusive cricket bonus.';

const schemaOrg = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Babu88',
      url: 'https://ipl-cricket-in.netlify.app',
    },
    {
      '@type': 'WebSite',
      name: 'Babu88',
      url: 'https://ipl-cricket-in.netlify.app',
    },
    {
      '@type': 'SportsEvent',
      name: 'Indian Premier League 2025',
      sport: 'Cricket',
      location: { '@type': 'Country', name: 'India' },
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </Fragment>

  <main class="lander">
    <div class="age-gate">18+ | Play Responsibly</div>

    <div class="lander-bg">
      <img
        src="/images/ipl-cricket-hero.webp"
        alt="IPL 2025 cricket stadium under floodlights"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="lander-content">
      <h1>Bet on <span>IPL 2025</span></h1>
      <p class="tagline">Best odds. Instant payouts. Exclusive bonus.</p>
      <a class="cta-btn" href="#signup" rel="noopener noreferrer" target="_blank">
        Join Babu88 Now
      </a>
    </div>

    <div class="footer-legal">&copy; 2025 Babu88 &middot; Gambling can be addictive. Play responsibly.</div>
  </main>
</BaseLayout>
